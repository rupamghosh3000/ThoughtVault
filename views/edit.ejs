<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post </title>
    <link rel="stylesheet" href="/style.css"/>
</head>
<body style="background-color: #f1f2f2;">

    <div class="edit-container">
        <h2 class="edit-header">Edit your post</h2>
        <div class="edit-meta">
            Editing post <strong>#<%= post.id %></strong> by <span>@<%= post.username %></span>
        </div>

        <form method="post" action="/posts/<%= post.id %>?_method=PATCH">
            <textarea name="content" rows="8"><%= post.content %></textarea>
            
            <div style="margin-top: 20px;">
                <button class="save-btn">Save Changes</button>
                <a href="/posts" class="cancel-link">Cancel</a>
            </div>
        </form>
    </div>

</body>
</html>